{
  "name": "neuralagent-desktop",
  "version": "1.5.7",
  "description": "NeuralAgent Electron Desktop Application",
  "license": "ISC",
  "author": "",
  "main": "main.js",
  "dependencies": {
    "express": "^4.21.2",
    "sudo-prompt": "^9.2.1",
    "tree-kill": "^1.2.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^41.7.1"
  },
  "build": {
    "publish": null,
    "asar": true,
    "extraResources": [
      {
        "from": "agent_build/agent.exe",
        "to": "agent.exe"
      },
      {
        "from": "agent_build/suggestor.exe",
        "to": "suggestor.exe"
      },
      {
        "from": "agent_build/cerebro.exe",
        "to": "cerebro.exe"
      }
    ]
  }
}
