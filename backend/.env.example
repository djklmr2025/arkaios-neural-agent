DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CONNECTION_STRING=

JWT_ISS=ARKAIOSBackend
JWT_SECRET=

# Keep Empty for now
REDIS_CONNECTION=

# ─── Google Gemini (Recommended for ARKAIOS) ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_TIMEOUT=20
GEMINI_MAX_RETRIES=1

# ─── OpenAI (Optional) ────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Anthropic Claude (Optional) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Azure OpenAI (Optional) ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-12-01-preview

# ─── AWS Bedrock (Optional) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-west-2

# ─── Agent Model Configuration ────────────────────────────────────────────────
# Puter can be used through its OpenAI-compatible endpoint. For browser/webview
# login use Puter.js directly in the client; for backend/desktop automation use
# a user-owned PUTER_AUTH_TOKEN generated from the user's Puter account.
PUTER_AUTH_TOKEN=
PUTER_OPENAI_BASE_URL=https://api.puter.com/puterai/openai/v1/
PUTER_TIMEOUT=30
PUTER_MAX_RETRIES=2

# model_type options: google | openai | azure_openai | anthropic | bedrock | puter

CLASSIFIER_AGENT_MODEL_TYPE=google
CLASSIFIER_AGENT_MODEL_ID=gemini-2.5-flash

TITLE_AGENT_MODEL_TYPE=google
TITLE_AGENT_MODEL_ID=gemini-2.5-flash

SUGGESTOR_AGENT_MODEL_TYPE=google
SUGGESTOR_AGENT_MODEL_ID=gemini-2.5-flash

PLANNER_AGENT_MODEL_TYPE=google
PLANNER_AGENT_MODEL_ID=gemini-2.5-flash

COMPUTER_USE_AGENT_MODEL_TYPE=google
COMPUTER_USE_AGENT_MODEL_ID=gemini-2.5-flash

# ─── Screenshot Logging (Training — keep false) ───────────────────────────────
ENABLE_SCREENSHOT_LOGGING_FOR_TRAINING=false
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# ─── LangSmith Tracing (Optional) ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# ─── Google OAuth Login (Optional) ───────────────────────────────────────────
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_DESKTOP_REDIRECT_URI=http://127.0.0.1:36478
